{
    "rewrites": [
        {
            "source": "/((?!assets/|.*\\..*).*)",
            "destination": "/index.html"
        }
    ],
    "redirects": [
        {
            "source": "/(?:.*)",
            "has": [
                {
                    "type": "host",
                    "value": "(.+\\.)?questionario\\.agendadoutor\\.com"
                }
            ],
            "destination": "https://agendadoutor.com/questionario"
        },
        {
            "source": "/(?:.*)",
            "has": [
                {
                    "type": "host",
                    "value": "questionario.agendadoutor.com"
                }
            ],
            "destination": "https://agendadoutor.com/questionario"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, s-maxage=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, s-maxage=0, must-revalidate, no-cache, no-store"
                }
            ]
        }
    ]
}